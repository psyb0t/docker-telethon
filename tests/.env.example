# Copy to .env and fill in. .env is gitignored.

# Required — Telegram app credentials (https://my.telegram.org/apps)
TELETHON_API_ID=123456
TELETHON_API_HASH=replace-me

# Required — string session minted via `make login` or login.py
TELETHON_SESSION=replace-me

# Required — chat to send test messages to. Use "me" for Saved Messages.
TEST_CHAT=me

# Optional — log level inside container during tests
TELETHON_LOG_LEVEL=INFO
