# Copy to .env and fill in. .env is gitignored.

# Required — Telegram app credentials (https://my.telegram.org/apps)
TELETHON_API_ID=123456
TELETHON_API_HASH=replace-me

# Required — string session minted via `make login`
TELETHON_SESSION=replace-me

# Optional — set to require Bearer token auth on all endpoints except /healthz
# TELETHON_AUTH_KEY=replace-with-a-strong-random-secret

# Optional
TELETHON_HTTP_LISTEN_ADDRESS=0.0.0.0:8080
TELETHON_LOG_LEVEL=INFO
TELETHON_REQUEST_TIMEOUT=60
TELETHON_FLOOD_SLEEP_THRESHOLD=60
TELETHON_DEVICE_MODEL=docker-telethon
TELETHON_SYSTEM_VERSION=1.0
TELETHON_APP_VERSION=1.0
TELETHON_DOWNLOAD_DIR=/tmp/telethon
# TELETHON_PROXY=socks5://user:pass@host:port

# Testing (used by `make test`)
TEST_CHAT=me
